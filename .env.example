# ==============================================================================
# SMIT CSC Monorepo - Environment Configuration Example
# ==============================================================================
# Copy this file to '.env' and fill in your custom keys for local development.
# e.g., cp .env.example .env
# ==============================================================================

# ─── Core Settings ───────────────────────────────────────────────────────────
NODE_ENV=development
PORT=5000
LOG_LEVEL=info

# Database Connection
# - Use 'db' as host when running inside Docker: postgresql://csc_admin:secure_db_password@db:5432/smit_csc
# - Use 'localhost' as host when running on host machine: postgresql://csc_admin:secure_db_password@localhost:5432/smit_csc
DATABASE_URL=postgresql://csc_admin:secure_db_password@localhost:5432/smit_csc

# Security Secrets (Please change these in production!)
JWT_SECRET=dev-secret-change-me
SESSION_SECRET=dev-session-secret-change-me

# Base Application Paths
APP_URL=http://smit-csc-info-api:5000
SMIT_CSC_BASE_PATH=/

# Local Object Storage Directories (Used when not running on Google Cloud Storage)
PUBLIC_OBJECT_SEARCH_PATHS=/tmp
PRIVATE_OBJECT_DIR=/tmp

# ─── PhonePe Payment Gateway ────────────────────────────────────────────────
PHONEPE_MERCHANT_ID=
PHONEPE_CLIENT_ID=
PHONEPE_CLIENT_SECRET=
PHONEPE_CLIENT_VERSION=1
PHONEPE_BASE_URL=

# ─── A1Topup Recharge Provider ──────────────────────────────────────────────
A1TOPUP_USERNAME=
A1TOPUP_PASSWORD=
A1TOPUP_BASE_URL=https://business.a1topup.com
A1TOPUP_WEBHOOK_SECRET=

# ─── Email (SMTP) ───────────────────────────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM="Smit CSC Info" <your-email@gmail.com>
ADMIN_EMAIL=

# ─── External APIs (Optional) ───────────────────────────────────────────────
GOOGLE_VISION_API_KEY=
AI_INTEGRATIONS_GEMINI_BASE_URL=https://generativelanguage.googleapis.com
AI_INTEGRATIONS_GEMINI_API_KEY=
REMOVE_BG_API_KEY=
YOUTUBE_API_KEY=
DATA_GOV_IN_API_KEY=
OPENWEATHER_API_KEY=
PIXABAY_API_KEY=
UNSPLASH_ACCESS_KEY=
NEWSAPI_AI_KEY=

# ─── EzyTM Operator Detection (Optional) ────────────────────────────────────
EZYTM_API_USERID=
EZYTM_API_PASSWORD=
